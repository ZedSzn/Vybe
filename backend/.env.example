PORT=3001

# ─── MongoDB Atlas (REQUIRED) ──────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Cluster → Connect → Drivers → Node.js
# Format:   mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

CLIENT_URL=http://localhost:5173

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Any long random string. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ─── Admin dashboard (secret URL: /admin-vybe-2024) ───────────────────────────
ADMIN_SECRET=
ADMIN_USERNAME=vybe_admin
ADMIN_PASSWORD=
ADMIN_EMAIL=

# ─── Stripe (optional — needed for ban removal payments) ──────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Get from: https://dashboard.stripe.com/webhooks (after creating a webhook endpoint)
STRIPE_WEBHOOK_SECRET=

# ─── Email / SMTP (optional — needed for email verification & password reset) ──
# For Gmail: use an App Password (Google Account → Security → 2-Step → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
